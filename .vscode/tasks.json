{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dotnet: clean",
            "command": "dotnet",
            "type": "process",
            "args": [
                "clean",
                "${workspaceFolder}/src/MX.CodDemoReader.sln"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/MX.CodDemoReader.sln"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: test",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/src/MX.CodDemoReader.sln",
                "--filter",
                "FullyQualifiedName!~IntegrationTests"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: format",
            "command": "dotnet",
            "type": "process",
            "args": [
                "format",
                "${workspaceFolder}/src/MX.CodDemoReader.sln",
                "--verify-no-changes"
            ]
        },
        {
            "label": "dotnet: build-release",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/MX.CodDemoReader.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary",
                "--configuration",
                "Release"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: test-release",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/src/MX.CodDemoReader.sln",
                "--configuration",
                "Release",
                "--filter",
                "FullyQualifiedName!~IntegrationTests"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}